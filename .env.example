# =============================================================================
# AgentGateway — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Naming convention: <IM>_BOT_TOKEN + <IM>_ALLOWED_USERS per IM adapter.

# --- Discord (optional: set to enable) ---------------------------------------
# Create at https://discord.com/developers/applications
# Required Intents: Message Content Intent, Server Members, Presence.
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Comma-separated Discord user IDs allowed to use the bot.
# Empty = reject all (fail-closed). Get ID via Discord dev mode > right-click self.
# DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432

# --- Telegram (optional: set to enable) --------------------------------------
# Create via @BotFather. Format: <numeric_id>:<alphanumeric_token>
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_ALLOWED_USERS=111111111,222222222

# --- Slack (optional: set to enable) ----------------------------------------
# 1. Create a Slack App at https://api.slack.com/apps
# 2. Enable Socket Mode (Settings > Socket Mode > Enable)
# 3. Create an App-Level Token with scope connections:write → SLACK_APP_TOKEN (xapp-...)
# 4. Add Bot Token Scopes (OAuth & Permissions):
#    app_mentions:read, chat:write, channels:history, groups:history,
#    im:history, im:read, im:write
# 5. Install the app to your workspace → SLACK_BOT_TOKEN (xoxb-...)
# 6. Subscribe to bot events: message.im, app_mention
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token
# SLACK_ALLOWED_USERS=U12345678,U87654321

# --- Shared -----------------------------------------------------------------
# Base working directory for AI session isolation.
# Each session gets <DEFAULT_CWD>/.sessions/<hash>/. Must exist and be writable.
DEFAULT_CWD=/home/user/workspace

# AI backends (comma-separated). At least one required.
# Available: claude-code, gemini, codex, opencode
# Users switch with /claude-code, /gemini, etc. prefix in chat.
AI_BACKENDS=claude-code

# Default AI backend (optional, defaults to first in AI_BACKENDS list)
# AI_DEFAULT=claude-code

# Claude Code model override (leave unset to use CLI default).
# Examples: opus, sonnet, claude-opus-4-7, claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-7

# Allow Bash tool in Claude Code invocations (default: false).
# Set to "true" only if you trust all whitelisted users with shell access.
CLAUDE_ALLOW_BASH=false
